# Weather Dashboard CLI - Variables de Entorno
# Copia este archivo a .env y completa los valores

# ============================================
# API KEY (OBLIGATORIO)
# ============================================
# Obtén tu API key gratuita en: https://openweathermap.org/api
# 1. Regístrate en OpenWeatherMap
# 2. Ve a "API Keys" en tu perfil
# 3. Copia tu API key aquí
OPENWEATHER_API_KEY=tu_api_key_aqui

# ============================================
# CONFIGURACIÓN OPCIONAL
# ============================================

# URL base de la API (no cambiar normalmente)
API_BASE_URL=https://api.openweathermap.org/data/2.5

# Timeout para requests en segundos
API_TIMEOUT=10

# Directorio para datos persistentes
DATA_DIR=data

# Nivel de logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
